blueprint:
  name: Rolladen Fensterposition Script
  description: Erzeugt ein Script für einen Rolladen mit wählbarer Position (hoch, runter, halb, dreiviertel) und konfigurierbaren Zeit-Helfern.
  domain: script
  source_url: ""
  input:
    target_button_hoch:
      name: Button Hoch
      description: Button-Entität zum Hochfahren des Rolladens
      selector:
        entity:
          domain: button
    target_button_runter:
      name: Button Runter
      description: Button-Entität zum Runterfahren des Rolladens
      selector:
        entity:
          domain: button
    target_button_stop:
      name: Button Stop
      description: Button-Entität zum Stoppen des Rolladens
      selector:
        entity:
          domain: button

    helper_komplett_zu:
      name: Helfer komplett zu
      description: input_number für „Fenster komplett zu“
      selector:
        entity:
          domain: input_number

    helper_halb_zu:
      name: Helfer halb zu
      description: input_number für „Fenster halb zu“
      selector:
        entity:
          domain: input_number

    helper_drei_viertel_zu:
      name: Helfer drei-viertel zu
      description: input_number für „Fenster drei-viertel zu“
      selector:
        entity:
          domain: input_number

    helper_gross_drei_viertel_zu:
      name: Helfer groß drei-viertel zu
      description: input_number für „Fenster groß drei-viertel zu“ (falls benötigt)
      selector:
        entity:
          domain: input_number

    ziel_position:
      name: Ziel-Position
      description: Endposition des Rolladens
      default: hoch
      selector:
        select:
          options:
            - label: Hoch
              value: hoch
            - label: Runter
              value: runter
            - label: Halb
              value: halb
            - label: Dreiviertel
              value: dreiviertel

mode: restart
alias: Rolladen Fensterposition ausgeführt
sequence:
  # Erst komplett hoch
  - action: button.press
    target:
      entity_id: !input target_button_hoch
    data: {}

  # Warten, bis komplett oben (nutzt Helfer "komplett_zu")
  - delay:
      seconds: "{{ states( (blueprint.inputs.helper_komplett_zu) ) | int }}"

  # Stop
  - action: button.press
    target:
      entity_id: !input target_button_stop
    data: {}

  # Je nach Ziel-Position weiterfahren nach unten
  - choose:
      # Nur "hoch": nichts weiter tun
      - conditions:
          - condition: template
            value_template: "{{ blueprint.inputs.ziel_position == 'hoch' }}"
        sequence: []

      # Nur komplett runter
      - conditions:
          - condition: template
            value_template: "{{ blueprint.inputs.ziel_position == 'runter' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input target_button_runter
            data: {}
          - delay:
              seconds: "{{ states( (blueprint.inputs.helper_komplett_zu) ) | int }}"
          - action: button.press
            target:
              entity_id: !input target_button_stop
            data: {}

      # Halb
      - conditions:
          - condition: template
            value_template: "{{ blueprint.inputs.ziel_position == 'halb' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input target_button_runter
            data: {}
          - delay:
              seconds: "{{ states( (blueprint.inputs.helper_halb_zu) ) | int }}"
          - action: button.press
            target:
              entity_id: !input target_button_stop
            data: {}

      # Dreiviertel (hier Beispiel mit helper_drei_viertel_zu)
      - conditions:
          - condition: template
            value_template: "{{ blueprint.inputs.ziel_position == 'dreiviertel' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input target_button_runter
            data: {}
          - delay:
              seconds: "{{ states( (blueprint.inputs.helper_drei_viertel_zu) ) | int }}"
          - action: button.press
            target:
              entity_id: !input target_button_stop
            data: {}
    default: []
