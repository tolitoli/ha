blueprint:
  name: Rolladen Position per Tastensteuerung
  description: >
    Erzeugt ein Script, das einen Rolladen über Tasten (hoch/stop/runter)
    auf eine Zielposition fährt (runter, hoch, halb zu, dreiviertel zu)
    und dabei auswählbare input_number-Helfer für die Zeiten nutzt.
  domain: script
  input:
    zielposition:
      name: Zielposition
      description: Zielposition des Rolladens
      selector:
        select:
          options:
            - label: Runter (komplett zu)
              value: runter
            - label: Hoch (komplett auf)
              value: hoch
            - label: Halb zu
              value: halb
            - label: Dreiviertel zu
              value: dreiviertel
          mode: dropdown
      default: runter

    button_hoch:
      name: Taste Hoch
      selector:
        entity:
          domain: button

    button_runter:
      name: Taste Runter
      selector:
        entity:
          domain: button

    button_stop:
      name: Taste Stop
      selector:
        entity:
          domain: button

    zeit_komplett_zu:
      name: Zeit komplett zu
      description: input_number für Zeit zum kompletten Schließen
      selector:
        entity:
          domain: input_number

    zeit_halb_zu:
      name: Zeit halb zu
      description: input_number für Zeit von unten bis halb zu
      selector:
        entity:
          domain: input_number

    zeit_dreiviertel_zu:
      name: Zeit dreiviertel zu
      description: input_number für Zeit von unten bis dreiviertel zu
      selector:
        entity:
          domain: input_number

    zeit_komplett_auf:
      name: Zeit komplett auf
      description: input_number für Zeit zum kompletten Öffnen
      selector:
        entity:
          domain: input_number

mode: restart
alias: Rolladen Position per Blueprint

sequence:
  # Zielposition: komplett runter (zu)
  - choose:
      - conditions:
          - condition: template
            value_template: "{{ zielposition == 'runter' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input button_runter
          - delay:
              seconds: "{{ states(zeit_komplett_zu) | int }}"
          - action: button.press
            target:
              entity_id: !input button_stop

      # Zielposition: komplett hoch (auf)
      - conditions:
          - condition: template
            value_template: "{{ zielposition == 'hoch' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input button_hoch
          - delay:
              seconds: "{{ states(zeit_komplett_auf) | int }}"
          - action: button.press
            target:
              entity_id: !input button_stop

      # Zielposition: halb zu
      - conditions:
          - condition: template
            value_template: "{{ zielposition == 'halb' }}"
        sequence:
          # Erst komplett hoch
          - action: button.press
            target:
              entity_id: !input button_hoch
          - delay:
              seconds: "{{ states(zeit_komplett_auf) | int }}"
          - action: button.press
            target:
              entity_id: !input button_stop
          # Dann runter bis halb zu
          - action: button.press
            target:
              entity_id: !input button_runter
          - delay:
              seconds: "{{ states(zeit_halb_zu) | int }}"
          - action: button.press
            target:
              entity_id: !input button_stop

      # Zielposition: dreiviertel zu
      - conditions:
          - condition: template
            value_template: "{{ zielposition == 'dreiviertel' }}"
        sequence:
          # Erst komplett hoch
          - action: button.press
            target:
              entity_id: !input button_hoch
          - delay:
              seconds: "{{ states(zeit_komplett_auf) | int }}"
          - action: button.press
            target:
              entity_id: !input button_stop
          # Dann runter bis dreiviertel zu
          - action: button.press
            target:
              entity_id: !input button_runter
          - delay:
              seconds: "{{ states(zeit_dreiviertel_zu) | int }}"
          - action: button.press
            target:
              entity_id: !input button_stop
    default: []

