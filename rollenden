blueprint:
  name: Rolladen Script – Fensterposition
  description: Erzeugt ein Script für eine definierte Fensterposition (halb / dreiviertel) mit frei wählbaren input_number‑Verzögerungen.
  domain: script
  source_url: https://example.com/rolladen-fensterposition-blueprint
  input:
    rolladen_hoch_button:
      name: Button Rolladen hoch
      description: Entity-ID des Hoch-Buttons (z.B. s7_plc_rolladen_wohnzimmer_strasse_hoch)
      selector:
        entity:
          domain: button
    rolladen_runter_button:
      name: Button Rolladen runter
      description: Entity-ID des Runter-Buttons
      selector:
        entity:
          domain: button
    rolladen_stop_button:
      name: Button Rolladen stop
      description: Entity-ID des Stop-Buttons
      selector:
        entity:
          domain: button

    ziel_position:
      name: Zielposition
      description: Welche Stellung soll angefahren werden?
      default: halb
      selector:
        select:
          mode: dropdown
          options:
            - label: Hoch / komplett auf
              value: hoch
            - label: Halb zu
              value: halb
            - label: Dreiviertel zu
              value: dreiviertel

    delay_komplett_zu:
      name: Zeit für komplett zu
      description: input_number für „Fenster komplett zu“
      selector:
        entity:
          domain: input_number

    delay_halb_zu:
      name: Zeit für halb zu
      description: input_number für „Fenster halb zu“
      selector:
        entity:
          domain: input_number

    delay_dreiviertel_zu:
      name: Zeit für dreiviertel zu
      description: input_number für „Fenster drei-viertel zu“
      selector:
        entity:
          domain: input_number

mode: restart
alias: Rolladen Fensterposition per Blueprint

sequence:
  # Zuerst komplett schließen (hoch oder runter, je nach deiner Logik – hier Beispiel: runter)
  - action: button.press
    target:
      entity_id: !input rolladen_runter_button

  - delay:
      seconds: "{{ states(!input delay_komplett_zu) | int }}"

  - action: button.press
    target:
      entity_id: !input rolladen_stop_button

  # Jetzt je nach Zielposition wieder ein Stück öffnen
  - choose:
      # Ziel: halb
      - conditions: "{{ !input ziel_position == 'halb' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input rolladen_hoch_button
          - delay:
              seconds: "{{ states(!input delay_halb_zu) | int }}"
          - action: button.press
            target:
              entity_id: !input rolladen_stop_button

      # Ziel: dreiviertel
      - conditions: "{{ !input ziel_position == 'dreiviertel' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input rolladen_hoch_button
          - delay:
              seconds: "{{ states(!input delay_dreiviertel_zu) | int }}"
          - action: button.press
            target:
              entity_id: !input rolladen_stop_button

      # Ziel: hoch (komplett auf) – optional: erst komplett zu, dann komplett hoch
      - conditions: "{{ !input ziel_position == 'hoch' }}"
        sequence:
          - action: button.press
            target:
              entity_id: !input rolladen_hoch_button
          # falls du dafür auch einen eigenen input_number hast, kannst du hier delay ergänzen
          # - delay:
          #     seconds: "{{ states('input_number.fenster_gross_komplett_auf') | int }}"
          - action: button.press
            target:
              entity_id: !input rolladen_stop_button
