blueprint:
  name: Rolladen Position über Zeit (S7)
  description: >
    Steuert einen Rolladen über S7-Taster mit Zeitsteuerung. 
    Zielposition: komplett zu (runter), komplett auf (hoch), halb zu oder dreiviertel zu.
  domain: script
  source_url: ""
  input:
    ziel_position:
      name: Zielposition
      description: Wohin soll der Rolladen fahren?
      selector:
        select:
          options:
            - label: Runter (komplett zu)
              value: runter
            - label: Hoch (komplett auf)
              value: hoch
            - label: Halb zu
              value: halb
            - label: Dreiviertel zu
              value: dreiviertel
          mode: dropdown
      default: runter

    btn_hoch:
      name: Button Hoch
      selector:
        entity:
          domain: button

    btn_runter:
      name: Button Runter
      selector:
        entity:
          domain: button

    btn_stop:
      name: Button Stop
      selector:
        entity:
          domain: button

    delay_komplett_zu:
      name: Zeit komplett zu
      description: input_number für Zeit von komplett auf nach komplett zu
      selector:
        entity:
          domain: input_number

    delay_halb_zu:
      name: Zeit halb zu
      description: input_number für Zeit von komplett zu nach halb zu
      selector:
        entity:
          domain: input_number

    delay_dreiviertel_zu:
      name: Zeit dreiviertel zu
      description: input_number für Zeit von komplett zu nach dreiviertel zu
      selector:
        entity:
          domain: input_number

script:
  sequence:
    - choose:
        # Ziel: komplett runter (zu)
        - conditions:
            - condition: template
              value_template: "{{ iif(blueprint.inputs.ziel_position is defined, blueprint.inputs.ziel_position, ziel_position) == 'runter' }}"
          sequence:
            - action: button.press
              target:
                entity_id: !input btn_runter
            - delay:
                seconds: "{{ states(!input delay_komplett_zu) | int }}"
            - action: button.press
              target:
                entity_id: !input btn_stop

        # Ziel: komplett hoch (auf)
        - conditions:
            - condition: template
              value_template: "{{ iif(blueprint.inputs.ziel_position is defined, blueprint.inputs.ziel_position, ziel_position) == 'hoch' }}"
          sequence:
            - action: button.press
              target:
                entity_id: !input btn_hoch
            - delay:
                seconds: "{{ states(!input delay_komplett_zu) | int }}"
            - action: button.press
              target:
                entity_id: !input btn_stop

        # Ziel: halb zu (erst komplett zu, dann wieder etwas hoch)
        - conditions:
            - condition: template
              value_template: "{{ iif(blueprint.inputs.ziel_position is defined, blueprint.inputs.ziel_position, ziel_position) == 'halb' }}"
          sequence:
            - action: button.press
              target:
                entity_id: !input btn_runter
            - delay:
                seconds: "{{ states(!input delay_komplett_zu) | int }}"
            - action: button.press
              target:
                entity_id: !input btn_stop
            - action: button.press
              target:
                entity_id: !input btn_hoch
            - delay:
                seconds: "{{ states(!input delay_halb_zu) | int }}"
            - action: button.press
              target:
                entity_id: !input btn_stop

        # Ziel: dreiviertel zu (erst komplett zu, dann weiter hoch)
        - conditions:
            - condition: template
              value_template: "{{ iif(blueprint.inputs.ziel_position is defined, blueprint.inputs.ziel_position, ziel_position) == 'dreiviertel' }}"
          sequence:
            - action: button.press
              target:
                entity_id: !input btn_runter
            - delay:
                seconds: "{{ states(!input delay_komplett_zu) | int }}"
            - action: button.press
              target:
                entity_id: !input btn_stop
            - action: button.press
              target:
                entity_id: !input btn_hoch
            - delay:
                seconds: "{{ states(!input delay_dreiviertel_zu) | int }}"
            - action: button.press
              target:
                entity_id: !input btn_stop
    - alias: Fertig
